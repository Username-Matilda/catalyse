# Committed defaults. Override any of these in .env.local (gitignored).

# Public URL of the app — used in email links.
APP_URL=http://localhost:3000

# From address for outgoing emails.
FROM_EMAIL=Catalyse <noreply@catalyse.pauseai.uk>

# Set to "true" to log emails to the console instead of sending them via Resend.
# Useful for local development.
STUB_EMAIL=true

# Comma-separated list of emails that are automatically promoted to admin on
# first login/signup.
ADMIN_EMAILS=
