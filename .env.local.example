# Local overrides — copy this to .env.local and fill in values.
# .env.local is gitignored and should never be committed.

# SQLite database path. Defaults to file:./catalyse.db if unset.
DATABASE_URL=file:./db/catalyse.db

# Google OAuth client ID — enables the "Sign in with Google" button.
# Get the value from production, then add http://localhost:3000 as an
# authorised JavaScript origin in Google Cloud Console.
GOOGLE_CLIENT_ID=

# Resend API key — required to send real emails (password reset, welcome, etc.).
# Leave unset (and set STUB_EMAIL=true in .env) to log emails to the console instead.
RESEND_API_KEY=

# Railway-only: path where the persistent volume is mounted (used for DB backups).
# Leave unset for local development.
# RAILWAY_VOLUME_MOUNT_PATH=/data

# Railway-only: secret token for cron endpoints. Set in Railway and pass as
# Authorization: Bearer <value> when triggering /api/cron/* routes.
# Leave unset for local development.
# CRON_SECRET=
