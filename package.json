{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "issue": "bash scripts/issue.sh",
    "local-setup": "cp -n .env.local.example .env.local; npm install && npm run install:browsers && npm run fetch-prod-db && npm run migrate && npm run generate",
    "check-all": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "dev": "next dev --turbo",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "lint": "eslint --cache",
    "lint:fix": "eslint --cache --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate": "npx prisma generate && tsx scripts/post-generate.ts",
    "build:railway": "tsx scripts/build-railway.ts",
    "new-migration": "tsx scripts/new-migration.ts",
    "migrate": "NODE_OPTIONS=--experimental-sqlite tsx scripts/migrate.ts",
    "fetch-prod-db": "NODE_OPTIONS=--experimental-sqlite tsx scripts/fetch-prod-db.ts",
    "install:browsers": "playwright install chromium --with-deps",
    "test": "playwright test",
    "test:dev": "E2E_DEV=1 playwright test",
    "test:log": "playwright test 2>&1 | tee test-output.txt",
    "test:dev:log": "E2E_DEV=1 playwright test 2>&1 | tee test-output.txt",
    "test:headed": "playwright test --headed --workers=1",
    "test:dev:headed": "E2E_DEV=1 playwright test --headed --workers=1",
    "test:ui": "SLOW_MO=800 playwright test --ui --headed --workers=1",
    "test:dev:ui": "E2E_DEV=1 SLOW_MO=800 playwright test --ui --headed --workers=1",
    "cron:backup": "tsx scripts/cron-backup.ts",
    "demo": "tsx demo/index.ts",
    "demo:snapshot": "tsx demo/snapshot.ts",
    "demo:compare": "tsx demo/compare.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@orpc/client": "^1.14.3",
    "@orpc/react-query": "^1.14.3",
    "@orpc/server": "^1.14.3",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.100.11",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.44.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "kokoro-js": "^1.2.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "zod-prisma-types": "^3.3.11"
  }
}
